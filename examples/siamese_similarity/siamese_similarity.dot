digraph Model {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_SiameseSimilarity {
        label=<<B>SiameseSimilarity</B><BR/><FONT POINT-SIZE="9">Model: 16 nodes</FONT>>;
        style=filled;
        fillcolor="#FFECB340";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
        subgraph cluster_SiameseSimilarity_shared_encoder {
            label=<<B>shared_encoder</B><BR/><FONT POINT-SIZE="8">Linear: [?, 1] → [?, 8]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=10;
            margin=8;
            "1" [label=<shared_encoder_W<BR/><B>Parameter</B><BR/>[1, 8]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "2" [label=<shared_encoder_b<BR/><B>Parameter</B><BR/>[1, 8]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<mat_mul_1<BR/><B>MatMul</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "8" [label=<add_1<BR/><B>Add</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<mat_mul_2<BR/><B>MatMul</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "11" [label=<add_2<BR/><B>Add</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }
        subgraph cluster_SiameseSimilarity_classifier {
            label=<<B>classifier</B><BR/><FONT POINT-SIZE="8">Linear: [?, 16] → [?, 1]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=10;
            margin=8;
            "3" [label=<classifier_W<BR/><B>Parameter</B><BR/>[16, 1]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "4" [label=<classifier_b<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "14" [label=<mat_mul_3<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "15" [label=<add_3<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }
            "5" [label=<input_1<BR/><B>SmartInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E0E0E0" fontsize=10];
            "6" [label=<input_2<BR/><B>SmartInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E0E0E0" fontsize=10];
            "9" [label=<leaky_relu_1<BR/><B>LeakyReLU</B><BR/>[?, 8]<BR/>α=0> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
            "12" [label=<leaky_relu_2<BR/><B>LeakyReLU</B><BR/>[?, 8]<BR/>α=0> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
            "13" [label=<concat_1<BR/><B>Concat</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "16" [label=<sigmoid_1<BR/><B>Sigmoid</B><BR/>[?, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    }

    "17" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "18" [label=<mse_1<BR/><B>MSE</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];

    "5" -> "7";
    "1" -> "7";
    "7" -> "8";
    "2" -> "8";
    "8" -> "9";
    "6" -> "10";
    "1" -> "10";
    "10" -> "11";
    "2" -> "11";
    "11" -> "12";
    "9" -> "13";
    "12" -> "13";
    "13" -> "14";
    "3" -> "14";
    "14" -> "15";
    "4" -> "15";
    "15" -> "16";
    "16" -> "18";
    "17" -> "18";
}
