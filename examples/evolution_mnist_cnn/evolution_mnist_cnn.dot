digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_EvolutionNet {
        label=<<B>EvolutionNet</B><BR/><FONT POINT-SIZE="9">(78,510 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_EvolutionNet_evo_L3 {
            label=<<B>evo_L3</B><BR/><FONT POINT-SIZE="9">Linear: [?, 7840] → [?, 10]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<evo_L3_b<BR/><B>Parameter</B><BR/>[1, 10]<BR/>(10 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<evo_L3_W<BR/><B>Parameter</B><BR/>[7840, 10]<BR/>(78,400 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_group_conv2d_0 {
            label=<<B>evo_conv1</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, ?, ?] → [?, 10, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "8" [label=<evo_conv1_out_1<BR/><B>Add</B><BR/>[?, 10, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "9" [label=<evo_conv1_conv_1<BR/><B>Conv2d</B><BR/>[?, 10, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "10" [label=<evo_conv1_b<BR/><B>Parameter</B><BR/>[1, 10, 1, 1]<BR/>(10 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "12" [label=<evo_conv1_K<BR/><B>Parameter</B><BR/>[10, 1, 3, 3]<BR/>(90 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "6" [label=<flatten_1<BR/><B>Flatten</B><BR/>[?, 7840]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "11" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 28, 28]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 10]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "9";
}
