digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_ParityRNN {
        label=<<B>ParityRNN</B><BR/><FONT POINT-SIZE="9">(322 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_ParityRNN_fc {
            label=<<B>fc</B><BR/><FONT POINT-SIZE="9">Linear: [?, 16] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "11625" [label=<add_9<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "11624" [label=<matmul_9<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<fc_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "4" [label=<fc_W<BR/><B>Parameter</B><BR/>[16, 2]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ParityRNN_rnn {
            label=<<B>rnn</B><BR/><FONT POINT-SIZE="9">RNN: [?, 1] → [?, 16] (×4-12 steps)</FONT>>;
            style="filled,bold";
            peripheries=3;
            penwidth=2;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
            "3" [label=<rnn_b_h<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "1" [label=<rnn_W_ih<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "2" [label=<rnn_W_hh<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "11605" [label=<tanh_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Tanh</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "11604" [label=<add_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "11603" [label=<add_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "11601" [label=<matmul_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "11602" [label=<matmul_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "11600" [label=<select_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "11599" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 16]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
        }

        "11598" [label=<input_1<BR/><B>Input</B><BR/>[?, 4-12, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "11627" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];
    "11626" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 2]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "11625" -> "11627";
    "11626" -> "11627";
    "11624" -> "11625";
    "5" -> "11625";
    "11605" -> "11624" [color="#E67E22" label=<t=3~11> fontcolor="#E67E22" fontsize=9];
    "4" -> "11624";
    "11604" -> "11605";
    "11603" -> "11604";
    "3" -> "11604";
    "11601" -> "11603";
    "11602" -> "11603";
    "11600" -> "11601";
    "1" -> "11601";
    "11599" -> "11602";
    "2" -> "11602";
    "11598" -> "11600";
    "11598" -> "11599" [style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "11605" -> "11599" [style=dashed color="#E67E22" label=<t=0~(2~10)> fontcolor="#E67E22" fontsize=9 constraint=false];
}
