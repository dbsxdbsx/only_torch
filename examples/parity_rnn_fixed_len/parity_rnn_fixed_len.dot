digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_ParityRNN {
        label=<<B>ParityRNN</B><BR/><FONT POINT-SIZE="9">(322 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_ParityRNN_fc {
            label=<<B>fc</B><BR/><FONT POINT-SIZE="9">Linear: [?, 16] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "34107" [label=<add_17<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "34106" [label=<matmul_17<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<fc_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "4" [label=<fc_W<BR/><B>Parameter</B><BR/>[16, 2]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ParityRNN_rnn {
            label=<<B>rnn</B><BR/><FONT POINT-SIZE="9">RNN: [?, 1] → [?, 16] (×8 steps)</FONT>>;
            style="filled,bold";
            peripheries=3;
            penwidth=2;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
            "3" [label=<rnn_b_h<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "1" [label=<rnn_W_ih<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "2" [label=<rnn_W_hh<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "34063" [label=<tanh_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Tanh</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "34062" [label=<add_2 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "34061" [label=<add_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "34059" [label=<matmul_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "34060" [label=<matmul_2 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "34058" [label=<select_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "34057" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 16]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
        }

        "34056" [label=<input_1<BR/><B>Input</B><BR/>[?, 8, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "34109" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];
    "34108" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 2]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "34107" -> "34109";
    "34108" -> "34109";
    "34106" -> "34107";
    "5" -> "34107";
    "34063" -> "34106" [color="#E67E22" label=<t=7> fontcolor="#E67E22" fontsize=9];
    "4" -> "34106";
    "34062" -> "34063";
    "34061" -> "34062";
    "3" -> "34062";
    "34059" -> "34061";
    "34060" -> "34061";
    "34058" -> "34059";
    "1" -> "34059";
    "34057" -> "34060";
    "2" -> "34060";
    "34056" -> "34058";
    "34056" -> "34057" [style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "34063" -> "34057" [style=dashed color="#E67E22" label=<t=0~6> fontcolor="#E67E22" fontsize=9 constraint=false];
}
