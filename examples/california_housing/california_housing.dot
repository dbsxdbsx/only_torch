digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_fc1 {
        label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 8] → [?, 128]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "3197" [label=<add_1<BR/><B>Add</B><BR/>[?, 128]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "3196" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 128]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "2" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 128]<BR/>(128 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "1" [label=<fc1_W<BR/><B>Parameter</B><BR/>[8, 128]<BR/>(1,024 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_fc2 {
        label=<<B>fc2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 128] → [?, 64]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "3200" [label=<add_2<BR/><B>Add</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "3199" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 64]<BR/>(64 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "3" [label=<fc2_W<BR/><B>Parameter</B><BR/>[128, 64]<BR/>(8,192 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_fc3 {
        label=<<B>fc3</B><BR/><FONT POINT-SIZE="9">Linear: [?, 64] → [?, 32]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "3203" [label=<add_3<BR/><B>Add</B><BR/>[?, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "3202" [label=<matmul_3<BR/><B>MatMul</B><BR/>[?, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "6" [label=<fc3_b<BR/><B>Parameter</B><BR/>[1, 32]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "5" [label=<fc3_W<BR/><B>Parameter</B><BR/>[64, 32]<BR/>(2,048 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_fc4 {
        label=<<B>fc4</B><BR/><FONT POINT-SIZE="9">Linear: [?, 32] → [?, 1]</FONT>>;
        style=filled;
        fillcolor="#F3E5F580";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "3206" [label=<add_4<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "3205" [label=<matmul_4<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "8" [label=<fc4_b<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<fc4_W<BR/><B>Parameter</B><BR/>[32, 1]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "3208" [label=<mse_1<BR/><B>MSE</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];
    "3207" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "3204" [label=<softplus_3<BR/><B>SoftPlus</B><BR/>[?, 32]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "3201" [label=<softplus_2<BR/><B>SoftPlus</B><BR/>[?, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "3198" [label=<softplus_1<BR/><B>SoftPlus</B><BR/>[?, 128]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "3195" [label=<input_1<BR/><B>Input</B><BR/>[?, 8]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "3206" -> "3208";
    "3207" -> "3208";
    "3205" -> "3206";
    "8" -> "3206";
    "3204" -> "3205";
    "7" -> "3205";
    "3203" -> "3204";
    "3202" -> "3203";
    "6" -> "3203";
    "3201" -> "3202";
    "5" -> "3202";
    "3200" -> "3201";
    "3199" -> "3200";
    "4" -> "3200";
    "3198" -> "3199";
    "3" -> "3199";
    "3197" -> "3198";
    "3196" -> "3197";
    "2" -> "3197";
    "3195" -> "3196";
    "1" -> "3196";
}
