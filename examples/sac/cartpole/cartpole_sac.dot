    "28" -> "25" [color="#D32F2F"];
    "29" -> "27" [color="#D32F2F"];
    "30" -> "29" [color="#D32F2F"];
    "31" -> "29" [color="#D32F2F"];
    "32" -> "30" [color="#D32F2F"];
    "33" -> "30" [color="#D32F2F"];
    "35" -> "34" [color="#388E3C"];
    "36" -> "34" [color="#388E3C"];
    "37" -> "35" [color="#388E3C"];
    "38" -> "35" [color="#388E3C"];
    "39" -> "37" [color="#388E3C"];
