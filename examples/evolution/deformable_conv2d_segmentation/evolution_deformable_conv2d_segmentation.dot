digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_conv2d_2 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 4, 16, 16] → [?, 1, 16, 16]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 1, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>Conv2d</B><BR/>[?, 1, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_17<BR/><B>Parameter</B><BR/>[1, 1, 1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_15<BR/><B>Parameter</B><BR/>[1, 4, 1, 1]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_deformableconv2d_1 {
        label=<<B>DeformableConv2d</B><BR/><FONT POINT-SIZE="9">DeformableConv2d: [?, 4, 16, 16] → [?, 4, 16, 16]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<evo_4<BR/><B>Add</B><BR/>[?, 4, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<evo_5<BR/><B>DeformableConv2d</B><BR/>[?, 4, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<evo_12<BR/><B>Parameter</B><BR/>[1, 4, 1, 1]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "12" [label=<evo_10<BR/><B>Parameter</B><BR/>[4, 4, 3, 3]<BR/>(144 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "13" [label=<evo_7<BR/><B>Add</B><BR/>[?, 18, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "15" [label=<evo_9<BR/><B>Conv2d</B><BR/>[?, 18, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "16" [label=<evo_8<BR/><B>Parameter</B><BR/>[1, 18, 1, 1]<BR/>(18 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "19" [label=<evo_6<BR/><B>Parameter</B><BR/>[18, 4, 3, 3]<BR/>(648 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_0 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, 16, 16] → [?, 4, 16, 16]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "14" [label=<evo_8<BR/><B>Add</B><BR/>[?, 4, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "17" [label=<evo_10<BR/><B>Conv2d</B><BR/>[?, 4, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "18" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 4, 1, 1]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "21" [label=<evo_1<BR/><B>Parameter</B><BR/>[4, 1, 3, 3]<BR/>(36 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1, 16, 16]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>ReLU</B><BR/>[?, 4, 16, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "11" [label=<evo_6<BR/><B>ReLU</B><BR/>[?, 4, 16, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "20" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 16, 16]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "9";
    "13" -> "9";
    "14" -> "11";
    "15" -> "13";
    "16" -> "13";
    "17" -> "14";
    "18" -> "14";
    "11" -> "15";
    "19" -> "15";
    "20" -> "17";
    "21" -> "17";
}
