digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_1 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 1] → [?, 1]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_7<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_5<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_gru_0 {
        label=<<B>GRU</B><BR/><FONT POINT-SIZE="9">[?, 8, 1] → [?, 1]</FONT>>;
        style="filled,bold";
        peripheries=3;
        penwidth=2;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<add_1<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<evo_48<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "10" [label=<evo_45<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "11" [label=<evo_46<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "13" [label=<evo_47<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "14" [label=<evo_43<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "15" [label=<evo_44<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "16" [label=<evo_42<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "17" [label=<evo_40<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "18" [label=<evo_41<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "19" [label=<add_2 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "20" [label=<tanh_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Tanh</B><BR/>[?, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "21" [label=<multiply_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Multiply</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "22" [label=<add_3 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "23" [label=<sigmoid_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Sigmoid</B><BR/>[?, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "24" [label=<subtract_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Subtract</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "25" [label=<add_4 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "26" [label=<add_5 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "27" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 1]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
