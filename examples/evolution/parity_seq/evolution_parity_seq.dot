            "39" [label=<matmul_6 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
    }

    "1" [label=<mse_1<BR/><B>MSE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>Mish</B><BR/>[?, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "12" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 8, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

