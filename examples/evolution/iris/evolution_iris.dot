digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_0 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 21] → [?, 3]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 3]<BR/>(3 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_1<BR/><B>Parameter</B><BR/>[21, 3]<BR/>(63 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_1 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 12] → [?, 21]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "6" [label=<evo_3<BR/><B>Add</B><BR/>[?, 21]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "8" [label=<evo_4<BR/><B>MatMul</B><BR/>[?, 21]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<evo_8<BR/><B>Parameter</B><BR/>[1, 21]<BR/>(21 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "11" [label=<evo_6<BR/><B>Parameter</B><BR/>[12, 21]<BR/>(252 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_2 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 12]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "10" [label=<evo_5<BR/><B>Add</B><BR/>[?, 12]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "12" [label=<evo_6<BR/><B>MatMul</B><BR/>[?, 12]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<evo_12<BR/><B>Parameter</B><BR/>[1, 12]<BR/>(12 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "15" [label=<evo_10<BR/><B>Parameter</B><BR/>[4, 12]<BR/>(48 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 3]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "14" [label=<evo_7<BR/><B>Tanh</B><BR/>[?, 4]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "16" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "6";
    "10" -> "8";
    "11" -> "8";
    "12" -> "10";
    "13" -> "10";
    "14" -> "12";
    "15" -> "12";
    "16" -> "14";
}
