digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_0 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 20] → [?, 3]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 3]<BR/>(3 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_1<BR/><B>Parameter</B><BR/>[20, 3]<BR/>(60 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_layernorm_3 {
        label=<<B>LayerNorm</B><BR/><FONT POINT-SIZE="9">LayerNorm: [?, 20] → [?, 20]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "6" [label=<evo_3<BR/><B>Add</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "8" [label=<evo_4<BR/><B>Multiply</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<evo_20<BR/><B>Parameter</B><BR/>[1, 20]<BR/>(20 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "10" [label=<evo_5<BR/><B>LayerNormOp</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "11" [label=<evo_17<BR/><B>Parameter</B><BR/>[1, 20]<BR/>(20 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_2 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 8] → [?, 20]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "12" [label=<evo_6<BR/><B>Add</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<evo_7<BR/><B>MatMul</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "14" [label=<evo_15<BR/><B>Parameter</B><BR/>[1, 20]<BR/>(20 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "16" [label=<evo_13<BR/><B>Parameter</B><BR/>[8, 20]<BR/>(160 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_1 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 8]</FONT>>;
        style=filled;
        fillcolor="#F3E5F580";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "15" [label=<evo_8<BR/><B>Add</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "17" [label=<evo_9<BR/><B>MatMul</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "18" [label=<evo_11<BR/><B>Parameter</B><BR/>[1, 8]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "20" [label=<evo_9<BR/><B>Parameter</B><BR/>[4, 8]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 3]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "19" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "6";
    "10" -> "8";
    "11" -> "8";
    "12" -> "10";
    "13" -> "12";
    "14" -> "12";
    "15" -> "13";
    "16" -> "13";
    "17" -> "15";
    "18" -> "15";
    "19" -> "17";
    "20" -> "17";
}
