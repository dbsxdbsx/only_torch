digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_EvolutionNet {
        label=<<B>EvolutionNet</B><BR/><FONT POINT-SIZE="9">(306 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_EvolutionNet_evo_L1 {
            label=<<B>evo_L1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 14] → [?, 3]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<evo_L1_b<BR/><B>Parameter</B><BR/>[1, 3]<BR/>(3 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<evo_L1_W<BR/><B>Parameter</B><BR/>[14, 3]<BR/>(42 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_evo_L2 {
            label=<<B>evo_L2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 13] → [?, 14]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "8" [label=<add_2<BR/><B>Add</B><BR/>[?, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "9" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "10" [label=<evo_L2_b<BR/><B>Parameter</B><BR/>[1, 14]<BR/>(14 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "12" [label=<evo_L2_W<BR/><B>Parameter</B><BR/>[13, 14]<BR/>(182 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_evo_L3 {
            label=<<B>evo_L3</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 13]</FONT>>;
            style=filled;
            fillcolor="#FFF3E080";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "11" [label=<add_3<BR/><B>Add</B><BR/>[?, 13]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "13" [label=<matmul_3<BR/><B>MatMul</B><BR/>[?, 13]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "14" [label=<evo_L3_b<BR/><B>Parameter</B><BR/>[1, 13]<BR/>(13 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "16" [label=<evo_L3_W<BR/><B>Parameter</B><BR/>[4, 13]<BR/>(52 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "6" [label=<softplus_1<BR/><B>SoftPlus</B><BR/>[?, 14]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "15" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 3]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "9";
    "13" -> "11";
    "14" -> "11";
    "15" -> "13";
    "16" -> "13";
}
