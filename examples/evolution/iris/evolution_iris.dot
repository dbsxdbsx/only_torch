digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_0 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 9] → [?, 3]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 3]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 3]<BR/>(3 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_1<BR/><B>Parameter</B><BR/>[9, 3]<BR/>(27 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_2 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 20] → [?, 9]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<evo_4<BR/><B>Add</B><BR/>[?, 9]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<evo_5<BR/><B>MatMul</B><BR/>[?, 9]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<evo_12<BR/><B>Parameter</B><BR/>[1, 9]<BR/>(9 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "12" [label=<evo_10<BR/><B>Parameter</B><BR/>[20, 9]<BR/>(180 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_1 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 20]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "11" [label=<evo_6<BR/><B>Add</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<evo_7<BR/><B>MatMul</B><BR/>[?, 20]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "14" [label=<evo_7<BR/><B>Parameter</B><BR/>[1, 20]<BR/>(20 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "16" [label=<evo_5<BR/><B>Parameter</B><BR/>[4, 20]<BR/>(80 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 3]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>HardSwish</B><BR/>[?, 9]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "15" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "9";
    "13" -> "11";
    "14" -> "11";
    "15" -> "13";
    "16" -> "13";
}
