digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_batchnorm_4 {
        label=<<B>BatchNorm</B><BR/><FONT POINT-SIZE="9">BatchNorm: [?, 56, 32, 32] → [?, 56, 32, 32]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "5" [label=<evo_2<BR/><B>Add</B><BR/>[?, 56, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "7" [label=<evo_3<BR/><B>Multiply</B><BR/>[?, 56, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "8" [label=<evo_21<BR/><B>Parameter</B><BR/>[1, 56, 1, 1]<BR/>(56 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "9" [label=<evo_4<BR/><B>BatchNormOp</B><BR/>[?, 56, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<evo_18<BR/><B>Parameter</B><BR/>[1, 56, 1, 1]<BR/>(56 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "2" [label=<evo_1<BR/><B>Identity</B><BR/>[?, 3, 32, 32]> shape=ellipse style="filled,dashed" fillcolor="#E0E0E0" fontsize=10];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 3, 32, 32]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "4" [label=<evo_merged_conv_1<BR/><B>Conv2d</B><BR/>[?, 3, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "6" [label=<evo_merged_kernel_757<BR/><B>Parameter</B><BR/>[3, 56, 5, 5]<BR/>(4,200 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    "11" [label=<evo_5<BR/><B>Identity</B><BR/>[?, 56, 32, 32]> shape=ellipse style="filled,dashed" fillcolor="#E0E0E0" fontsize=10];
    "12" [label=<evo_merged_conv_2<BR/><B>Conv2d</B><BR/>[?, 56, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "13" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 32, 32]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    "14" [label=<evo_merged_kernel_1095<BR/><B>Parameter</B><BR/>[56, 1, 1, 1]<BR/>(56 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "4";
    "6" -> "4";
    "7" -> "5";
    "8" -> "5";
    "9" -> "7";
    "10" -> "7";
    "11" -> "9";
    "12" -> "11";
    "13" -> "12";
    "14" -> "12";
}
