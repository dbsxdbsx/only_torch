digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_conv2d_1 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 8, 32, 32] → [?, 3, 32, 32]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 3, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>Conv2d</B><BR/>[?, 3, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_7<BR/><B>Parameter</B><BR/>[1, 3, 1, 1]<BR/>(3 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_5<BR/><B>Parameter</B><BR/>[3, 8, 1, 1]<BR/>(24 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_0 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, 32, 32] → [?, 8, 32, 32]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<evo_4<BR/><B>Add</B><BR/>[?, 8, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<evo_6<BR/><B>Conv2d</B><BR/>[?, 8, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "11" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "15" [label=<evo_1<BR/><B>Parameter</B><BR/>[8, 1, 3, 3]<BR/>(72 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_2 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, 32, 32] → [?, 8, 32, 32]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "9" [label=<evo_5<BR/><B>Add</B><BR/>[?, 8, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "12" [label=<evo_7<BR/><B>Conv2d</B><BR/>[?, 8, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<evo_11<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "16" [label=<evo_9<BR/><B>Parameter</B><BR/>[8, 1, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 3, 32, 32]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>Add</B><BR/>[?, 8, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "14" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 32, 32]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "6";
    "10" -> "8";
    "11" -> "8";
    "12" -> "9";
    "13" -> "9";
    "14" -> "10";
    "15" -> "10";
    "14" -> "12";
    "16" -> "12";
}
