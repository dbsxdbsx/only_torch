digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_1 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 1] → [?, 1]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_7<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_5<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_rnn_0 {
        label=<<B>rnn_rebuilt</B><BR/><FONT POINT-SIZE="9">RNN: [?, 1] → [?, 1] (×12 steps)</FONT>>;
        style="filled,bold";
        peripheries=3;
        penwidth=2;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<evo_39<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "9" [label=<evo_37<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "10" [label=<evo_38<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "12" [label=<tanh_1 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Tanh</B><BR/>[?, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "13" [label=<add_1 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "14" [label=<add_2 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "15" [label=<matmul_1 <FONT COLOR="#E67E22">×12</FONT><BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "16" [label=<matmul_2 <FONT COLOR="#E67E22">×12</FONT><BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "17" [label=<select_1 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "18" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 1]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>ReLU</B><BR/>[?, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "11" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 12, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "12" -> "6" [ color="#E67E22" label=<t=11> fontcolor="#E67E22" fontsize=9];
    "13" -> "12";
    "14" -> "13";
    "8" -> "13";
    "15" -> "14";
    "16" -> "14";
    "17" -> "15";
    "9" -> "15";
    "18" -> "16";
    "10" -> "16";
    "11" -> "17";
    "11" -> "18" [ style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "12" -> "18" [style=dashed color="#E67E22" label=<t=0~10> fontcolor="#E67E22" fontsize=9 constraint=false];
}
