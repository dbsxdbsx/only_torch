digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_EvolutionNet {
        label=<<B>EvolutionNet</B><BR/><FONT POINT-SIZE="9">(61 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_EvolutionNet_evo_L2 {
            label=<<B>evo_L2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 13] → [?, 1]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<evo_L2_b<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<evo_L2_W<BR/><B>Parameter</B><BR/>[13, 1]<BR/>(13 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_evo_L11 {
            label=<<B>evo_L11</B><BR/><FONT POINT-SIZE="9">Linear: [?, 2] → [?, 13]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "6" [label=<add_2<BR/><B>Add</B><BR/>[?, 13]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "8" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 13]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "9" [label=<evo_L11_b<BR/><B>Parameter</B><BR/>[1, 13]<BR/>(13 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "11" [label=<evo_L11_W<BR/><B>Parameter</B><BR/>[2, 13]<BR/>(26 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_evo_rnn1 {
            label=<<B>evo_rnn1</B><BR/><FONT POINT-SIZE="9">RNN: [?, 1] → [?, 2] (×12 steps)</FONT>>;
            style="filled,bold";
            peripheries=3;
            penwidth=2;
            fillcolor="#FFF3E080";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "15" [label=<evo_rnn1_b_h<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "16" [label=<evo_rnn1_W_ih<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "17" [label=<evo_rnn1_W_hh<BR/><B>Parameter</B><BR/>[2, 2]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "20" [label=<tanh_1 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Tanh</B><BR/>[?, 2]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "21" [label=<add_4 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "22" [label=<add_5 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "23" [label=<matmul_3 <FONT COLOR="#E67E22">×12</FONT><BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "24" [label=<matmul_4 <FONT COLOR="#E67E22">×12</FONT><BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "25" [label=<select_1 <FONT COLOR="#E67E22">×12</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "26" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 2]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
        }

        "10" [label=<multiply_1<BR/><B>Multiply</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "12" [label=<add_3<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "13" [label=<input_1<BR/><B>Input</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
        "14" [label=<swish_1<BR/><B>Swish</B><BR/>[?, 2]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "18" [label=<hard_swish_1<BR/><B>HardSwish</B><BR/>[?, 12, 1]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "19" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 12, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "6";
    "10" -> "8";
    "11" -> "8";
    "12" -> "10";
    "13" -> "10";
    "14" -> "12";
    "20" -> "12" [ color="#E67E22" label=<t=11> fontcolor="#E67E22" fontsize=9];
    "20" -> "14" [ color="#E67E22" label=<t=11> fontcolor="#E67E22" fontsize=9];
    "19" -> "18";
    "21" -> "20";
    "22" -> "21";
    "15" -> "21";
    "23" -> "22";
    "24" -> "22";
    "25" -> "23";
    "16" -> "23";
    "26" -> "24";
    "17" -> "24";
    "18" -> "25";
    "18" -> "26" [ style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "20" -> "26" [style=dashed color="#E67E22" label=<t=0~10> fontcolor="#E67E22" fontsize=9 constraint=false];
}
