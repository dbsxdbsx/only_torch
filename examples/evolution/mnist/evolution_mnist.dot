digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_EvolutionNet {
        label=<<B>EvolutionNet</B><BR/><FONT POINT-SIZE="9">(9,946 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_EvolutionNet_evo_L2 {
            label=<<B>evo_L2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 48] → [?, 10]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<evo_L2_b<BR/><B>Parameter</B><BR/>[1, 10]<BR/>(10 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<evo_L2_W<BR/><B>Parameter</B><BR/>[48, 10]<BR/>(480 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_evo_L4 {
            label=<<B>evo_L4</B><BR/><FONT POINT-SIZE="9">Linear: [?, 196] → [?, 48]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "6" [label=<add_2<BR/><B>Add</B><BR/>[?, 48]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "8" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 48]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "9" [label=<evo_L4_b<BR/><B>Parameter</B><BR/>[1, 48]<BR/>(48 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "11" [label=<evo_L4_W<BR/><B>Parameter</B><BR/>[196, 48]<BR/>(9,408 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "10" [label=<flatten_1<BR/><B>Flatten</B><BR/>[?, 196]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "12" [label=<evo_pool5_out_1<BR/><B>AvgPool2d</B><BR/>[?, 1, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "13" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 28, 28]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 10]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "6";
    "10" -> "8";
    "11" -> "8";
    "12" -> "10";
    "13" -> "12";
}
