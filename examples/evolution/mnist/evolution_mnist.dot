digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_3 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 1568] → [?, 10]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_9<BR/><B>Parameter</B><BR/>[1, 10]<BR/>(10 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_7<BR/><B>Parameter</B><BR/>[1568, 10]<BR/>(15,680 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_0 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, 28, 28] → [?, 8, 28, 28]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "11" [label=<evo_7<BR/><B>Add</B><BR/>[?, 8, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "12" [label=<evo_8<BR/><B>Conv2d</B><BR/>[?, 8, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "15" [label=<evo_1<BR/><B>Parameter</B><BR/>[8, 1, 7, 7]<BR/>(392 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 10]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>Flatten</B><BR/>[?, 1568]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "8" [label=<evo_4<BR/><B>HardSwish</B><BR/>[?, 8, 14, 14]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "9" [label=<evo_5<BR/><B>Mish</B><BR/>[?, 8, 14, 14]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "10" [label=<evo_6<BR/><B>MaxPool2d</B><BR/>[?, 8, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "14" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 28, 28]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "9";
    "11" -> "10";
    "12" -> "11";
    "13" -> "11";
    "14" -> "12";
    "15" -> "12";
}
