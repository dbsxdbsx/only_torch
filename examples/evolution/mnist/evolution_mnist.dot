digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_linear_3 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 24] → [?, 10]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>MatMul</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_21<BR/><B>Parameter</B><BR/>[1, 10]<BR/>(10 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_19<BR/><B>Parameter</B><BR/>[24, 10]<BR/>(240 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_linear_2 {
        label=<<B>Linear</B><BR/><FONT POINT-SIZE="9">Linear: [?, 392] → [?, 24]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<evo_4<BR/><B>Add</B><BR/>[?, 24]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<evo_5<BR/><B>MatMul</B><BR/>[?, 24]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<evo_16<BR/><B>Parameter</B><BR/>[1, 24]<BR/>(24 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "12" [label=<evo_14<BR/><B>Parameter</B><BR/>[392, 24]<BR/>(9,408 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 10]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>ReLU</B><BR/>[?, 24]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "11" [label=<evo_6<BR/><B>Flatten</B><BR/>[?, 392]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "13" [label=<evo_7<BR/><B>MaxPool2d</B><BR/>[?, 8, 7, 7]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "14" [label=<evo_8<BR/><B>ReLU</B><BR/>[?, 8, 14, 14]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "15" [label=<evo_9<BR/><B>Identity</B><BR/>[?, 8, 14, 14]> shape=ellipse style="filled,dashed" fillcolor="#E0E0E0" fontsize=10];
    "16" [label=<evo_merged_conv_1<BR/><B>Conv2d</B><BR/>[?, 8, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "17" [label=<evo_10<BR/><B>MaxPool2d</B><BR/>[?, 1, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "18" [label=<evo_merged_kernel_72<BR/><B>Parameter</B><BR/>[8, 1, 3, 3]<BR/>(72 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    "19" [label=<evo_11<BR/><B>ReLU</B><BR/>[?, 1, 28, 28]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "20" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 28, 28]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "9";
    "13" -> "11";
    "14" -> "13";
    "15" -> "14";
    "16" -> "15";
    "17" -> "16";
    "18" -> "16";
    "19" -> "17";
    "20" -> "19";
}
