digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_conv2d_4 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 16, 64, 64] → [?, 4, 64, 64]</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<evo_1<BR/><B>Add</B><BR/>[?, 4, 64, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<evo_2<BR/><B>Conv2d</B><BR/>[?, 4, 64, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<evo_25<BR/><B>Parameter</B><BR/>[1, 4, 1, 1]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<evo_23<BR/><B>Parameter</B><BR/>[4, 16, 1, 1]<BR/>(64 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_convtranspose2d_2 {
        label=<<B>ConvTranspose2d</B><BR/><FONT POINT-SIZE="9">ConvTranspose2d: [?, 16, 32, 32] → [?, 8, 64, 64]</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "11" [label=<evo_7<BR/><B>Add</B><BR/>[?, 8, 64, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<evo_9<BR/><B>ConvTranspose2d</B><BR/>[?, 8, 64, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "14" [label=<evo_14<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "18" [label=<evo_12<BR/><B>Parameter</B><BR/>[16, 8, 2, 2]<BR/>(512 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_0 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, 64, 64] → [?, 8, 64, 64]</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "12" [label=<evo_8<BR/><B>Add</B><BR/>[?, 8, 64, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "15" [label=<evo_10<BR/><B>Conv2d</B><BR/>[?, 8, 64, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "16" [label=<evo_3<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "20" [label=<evo_1<BR/><B>Parameter</B><BR/>[8, 1, 3, 3]<BR/>(72 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_1 {
        label=<<B>Conv2d</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 8, 32, 32] → [?, 16, 32, 32]</FONT>>;
        style=filled;
        fillcolor="#F3E5F580";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "21" [label=<evo_12<BR/><B>Add</B><BR/>[?, 16, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "22" [label=<evo_13<BR/><B>Conv2d</B><BR/>[?, 16, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "23" [label=<evo_9<BR/><B>Parameter</B><BR/>[1, 16, 1, 1]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "25" [label=<evo_7<BR/><B>Parameter</B><BR/>[16, 8, 3, 3]<BR/>(1,152 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 4, 64, 64]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<evo_3<BR/><B>ReLU</B><BR/>[?, 16, 64, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "8" [label=<evo_4<BR/><B>Concat</B><BR/>[?, 16, 64, 64]> shape=invtrapezium style=filled fillcolor="#E0F2F1" fontsize=10];
    "9" [label=<evo_5<BR/><B>ReLU</B><BR/>[?, 8, 64, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "10" [label=<evo_6<BR/><B>ReLU</B><BR/>[?, 8, 64, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "17" [label=<evo_11<BR/><B>ReLU</B><BR/>[?, 16, 32, 32]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "19" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 1, 64, 64]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    "24" [label=<evo_14<BR/><B>MaxPool2d</B><BR/>[?, 8, 32, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "10";
    "13" -> "11";
    "14" -> "11";
    "15" -> "12";
    "16" -> "12";
    "17" -> "13";
    "18" -> "13";
    "19" -> "15";
    "20" -> "15";
    "21" -> "17";
    "22" -> "21";
    "23" -> "21";
    "24" -> "22";
    "25" -> "22";
    "10" -> "24";
}
