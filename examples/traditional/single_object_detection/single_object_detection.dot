digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_SingleObjectDetectionNet {
        label=<<B>SingleObjectDetectionNet</B><BR/><FONT POINT-SIZE="9">(17,956 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_SingleObjectDetectionNet_bbox_head {
            label=<<B>bbox_head</B><BR/><FONT POINT-SIZE="9">Linear: [?, 64] → [?, 4]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "4" [label=<add_1<BR/><B>Add</B><BR/>[?, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "6" [label=<bbox_head_b<BR/><B>Parameter</B><BR/>[1, 4]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "8" [label=<bbox_head_W<BR/><B>Parameter</B><BR/>[64, 4]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_SingleObjectDetectionNet_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 256] → [?, 64]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "9" [label=<add_2<BR/><B>Add</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "10" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "11" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 64]<BR/>(64 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "13" [label=<fc1_W<BR/><B>Parameter</B><BR/>[256, 64]<BR/>(16,384 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_SingleObjectDetectionNet_group_conv2d_1 {
            label=<<B>conv2</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 8, ?, ?] → [?, 16, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "16" [label=<conv2_out_1<BR/><B>Add</B><BR/>[?, 16, 8, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "17" [label=<conv2_conv_1<BR/><B>Conv2d</B><BR/>[?, 16, 8, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "18" [label=<conv2_b<BR/><B>Parameter</B><BR/>[1, 16, 1, 1]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "20" [label=<conv2_K<BR/><B>Parameter</B><BR/>[16, 8, 3, 3]<BR/>(1,152 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_SingleObjectDetectionNet_group_conv2d_0 {
            label=<<B>conv1</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, ?, ?] → [?, 8, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "22" [label=<conv1_out_1<BR/><B>Add</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "23" [label=<conv1_conv_1<BR/><B>Conv2d</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "24" [label=<conv1_b<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "26" [label=<conv1_K<BR/><B>Parameter</B><BR/>[8, 1, 3, 3]<BR/>(72 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "2" [label=<sigmoid_1<BR/><B>Sigmoid</B><BR/>[?, 4]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "7" [label=<relu_1<BR/><B>ReLU</B><BR/>[?, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "12" [label=<flatten_1<BR/><B>Flatten</B><BR/>[?, 256]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "14" [label=<pool2_out_1<BR/><B>MaxPool2d</B><BR/>[?, 16, 4, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "15" [label=<relu_2<BR/><B>ReLU</B><BR/>[?, 16, 8, 8]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "19" [label=<pool1_out_1<BR/><B>MaxPool2d</B><BR/>[?, 8, 8, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "21" [label=<relu_3<BR/><B>ReLU</B><BR/>[?, 8, 16, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "25" [label=<input_1<BR/><B>Input</B><BR/>[?, 1, 16, 16]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<huber_1<BR/><B>Huber</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "4";
    "6" -> "4";
    "7" -> "5";
    "8" -> "5";
    "9" -> "7";
    "10" -> "9";
    "11" -> "9";
    "12" -> "10";
    "13" -> "10";
    "14" -> "12";
    "15" -> "14";
    "16" -> "15";
    "17" -> "16";
    "18" -> "16";
    "19" -> "17";
    "20" -> "17";
    "21" -> "19";
    "22" -> "21";
    "23" -> "22";
    "24" -> "22";
    "25" -> "23";
    "26" -> "23";
}
