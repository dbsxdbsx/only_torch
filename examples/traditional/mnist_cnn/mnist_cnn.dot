digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_MnistCNN {
        label=<<B>MnistCNN</B><BR/><FONT POINT-SIZE="9">(13,242 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_MnistCNN_fc2 {
            label=<<B>fc2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 32] → [?, 10]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 10]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 10]<BR/>(10 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<fc2_W<BR/><B>Parameter</B><BR/>[32, 10]<BR/>(320 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_MnistCNN_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 392] → [?, 32]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "9" [label=<add_2<BR/><B>Add</B><BR/>[?, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "10" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 32]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "11" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 32]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "13" [label=<fc1_W<BR/><B>Parameter</B><BR/>[392, 32]<BR/>(12,544 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_MnistCNN_group_conv2d_1 {
            label=<<B>conv2</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 4, ?, ?] → [?, 8, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "16" [label=<conv2_out_1<BR/><B>Add</B><BR/>[?, 8, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "17" [label=<conv2_conv_1<BR/><B>Conv2d</B><BR/>[?, 8, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "18" [label=<conv2_b<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "20" [label=<conv2_K<BR/><B>Parameter</B><BR/>[8, 4, 3, 3]<BR/>(288 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_MnistCNN_group_conv2d_0 {
            label=<<B>conv1</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, ?, ?] → [?, 4, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "22" [label=<conv1_out_1<BR/><B>Add</B><BR/>[?, 4, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "23" [label=<conv1_conv_1<BR/><B>Conv2d</B><BR/>[?, 4, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "24" [label=<conv1_b<BR/><B>Parameter</B><BR/>[1, 4, 1, 1]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "26" [label=<conv1_K<BR/><B>Parameter</B><BR/>[4, 1, 3, 3]<BR/>(36 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "6" [label=<dropout_1<BR/><B>Dropout</B><BR/>[?, 32]<BR/>(p=0.2)> shape=diamond style=filled fillcolor="#E1BEE7" fontsize=10];
        "8" [label=<relu_1<BR/><B>ReLU</B><BR/>[?, 32]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "12" [label=<flatten_1<BR/><B>Flatten</B><BR/>[?, 392]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "14" [label=<pool2_out_1<BR/><B>MaxPool2d</B><BR/>[?, 8, 7, 7]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "15" [label=<relu_2<BR/><B>ReLU</B><BR/>[?, 8, 14, 14]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "19" [label=<pool1_out_1<BR/><B>MaxPool2d</B><BR/>[?, 4, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "21" [label=<relu_3<BR/><B>ReLU</B><BR/>[?, 4, 28, 28]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "25" [label=<input_1<BR/><B>Input</B><BR/>[?, 1, 28, 28]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 10]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "9";
    "11" -> "9";
    "12" -> "10";
    "13" -> "10";
    "14" -> "12";
    "15" -> "14";
    "16" -> "15";
    "17" -> "16";
    "18" -> "16";
    "19" -> "17";
    "20" -> "17";
    "21" -> "19";
    "22" -> "21";
    "23" -> "22";
    "24" -> "22";
    "25" -> "23";
    "26" -> "23";
}
