digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_group_conv2d_3 {
        label=<<B>head</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 8, ?, ?] → [?, 1, ?, ?], kernel 1×1</FONT>>;
        style=filled;
        fillcolor="#E3F2FD80";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "2" [label=<head_out_1<BR/><B>Add</B><BR/>[?, 1, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "4" [label=<head_conv_1<BR/><B>Conv2d</B><BR/>[?, 1, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "5" [label=<head_b<BR/><B>Parameter</B><BR/>[1, 1, 1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "7" [label=<head_K<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_2 {
        label=<<B>refine</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 8, ?, ?] → [?, 8, ?, ?], kernel 3×3</FONT>>;
        style=filled;
        fillcolor="#E8F5E980";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "8" [label=<refine_out_1<BR/><B>Add</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "9" [label=<refine_conv_1<BR/><B>Conv2d</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<refine_b<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "12" [label=<refine_K<BR/><B>Parameter</B><BR/>[8, 8, 3, 3]<BR/>(576 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_deformableconv2d_1 {
        label=<<B>deform</B><BR/><FONT POINT-SIZE="9">DeformableConv2d: [?, 8, ?, ?] → [?, 8, ?, ?], kernel 3×3, deformable_groups=1</FONT>>;
        style=filled;
        fillcolor="#FFF3E080";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "13" [label=<deform_out_1<BR/><B>Add</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "14" [label=<deform_deform_1<BR/><B>DeformableConv2d</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "15" [label=<deform_b<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "17" [label=<deform_K<BR/><B>Parameter</B><BR/>[8, 8, 3, 3]<BR/>(576 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "18" [label=<deform_offset_1<BR/><B>Add</B><BR/>[?, 18, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "20" [label=<deform_offset_conv_1<BR/><B>Conv2d</B><BR/>[?, 18, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "21" [label=<deform_offset_b<BR/><B>Parameter</B><BR/>[1, 18, 1, 1]<BR/>(18 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "24" [label=<deform_offset_K<BR/><B>Parameter</B><BR/>[18, 8, 3, 3]<BR/>(1,296 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    subgraph cluster_group_conv2d_0 {
        label=<<B>stem</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 1, ?, ?] → [?, 8, ?, ?], kernel 3×3</FONT>>;
        style=filled;
        fillcolor="#F3E5F580";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
            "19" [label=<stem_out_1<BR/><B>Add</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "22" [label=<stem_conv_1<BR/><B>Conv2d</B><BR/>[?, 8, 16, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "23" [label=<stem_b<BR/><B>Parameter</B><BR/>[1, 8, 1, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "26" [label=<stem_K<BR/><B>Parameter</B><BR/>[8, 1, 3, 3]<BR/>(72 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
    }

    "1" [label=<bce_1<BR/><B>BCE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1, 16, 16]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<relu_1<BR/><B>ReLU</B><BR/>[?, 8, 16, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "11" [label=<relu_2<BR/><B>ReLU</B><BR/>[?, 8, 16, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "16" [label=<relu_3<BR/><B>ReLU</B><BR/>[?, 8, 16, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    "25" [label=<input_1<BR/><B>Input</B><BR/>[?, 1, 16, 16]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "8";
    "10" -> "8";
    "11" -> "9";
    "12" -> "9";
    "13" -> "11";
    "14" -> "13";
    "15" -> "13";
    "16" -> "14";
    "17" -> "14";
    "18" -> "14";
    "19" -> "16";
    "20" -> "18";
    "21" -> "18";
    "22" -> "19";
    "23" -> "19";
    "16" -> "20";
    "24" -> "20";
    "25" -> "22";
    "26" -> "22";
}
