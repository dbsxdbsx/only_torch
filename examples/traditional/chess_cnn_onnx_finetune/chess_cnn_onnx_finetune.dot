                "25" [label=<conv2_b<BR/><B>Parameter</B><BR/>[1, 32, 1, 1]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "27" [label=<conv2_K<BR/><B>Parameter</B><BR/>[32, 16, 3, 3]<BR/>(4,608 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
