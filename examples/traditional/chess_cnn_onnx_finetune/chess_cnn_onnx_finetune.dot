                "32" [label=<bn1_norm_1<BR/><B>BatchNormOp</B><BR/>[?, 16, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "33" [label=<reshape_4<BR/><B>Reshape</B><BR/>[?, 16, 1, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
