digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_ChessPieceCNN {
        label=<<B>ChessPieceCNN</B><BR/><FONT POINT-SIZE="9">(207,951 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_ChessPieceCNN_fc2 {
            label=<<B>fc2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 128] → [?, 15]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 15]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 15]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 15]<BR/>(15 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<fc2_W<BR/><B>Parameter</B><BR/>[128, 15]<BR/>(1,920 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ChessPieceCNN_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 1568] → [?, 128]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "9" [label=<add_2<BR/><B>Add</B><BR/>[?, 128]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "10" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 128]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "11" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 128]<BR/>(128 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "13" [label=<fc1_W<BR/><B>Parameter</B><BR/>[1568, 128]<BR/>(200,704 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ChessPieceCNN_group_batchnorm_3 {
            label=<<B>bn2</B><BR/><FONT POINT-SIZE="9">BatchNorm: C=32</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "16" [label=<add_3<BR/><B>Add</B><BR/>[?, 32, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "17" [label=<multiply_1<BR/><B>Multiply</B><BR/>[?, 32, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "18" [label=<reshape_1<BR/><B>Reshape</B><BR/>[?, 32, 1, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "19" [label=<bn2_norm_1<BR/><B>BatchNormOp</B><BR/>[?, 32, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "20" [label=<reshape_2<BR/><B>Reshape</B><BR/>[?, 32, 1, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "21" [label=<bn2_beta<BR/><B>Parameter</B><BR/>[1, 32]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "23" [label=<bn2_gamma<BR/><B>Parameter</B><BR/>[1, 32]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ChessPieceCNN_group_conv2d_2 {
            label=<<B>conv2</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 16, ?, ?] → [?, 32, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "22" [label=<conv2_out_1<BR/><B>Add</B><BR/>[?, 32, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
