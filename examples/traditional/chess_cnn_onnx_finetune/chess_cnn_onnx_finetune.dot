                "36" [label=<bn1_gamma<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ChessPieceCNN_group_conv2d_0 {
            label=<<B>conv1</B><BR/><FONT POINT-SIZE="9">Conv2d: [?, 3, ?, ?] → [?, 16, ?, ?], kernel 3×3</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
