                "37" [label=<conv1_conv_1<BR/><B>Conv2d</B><BR/>[?, 16, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "38" [label=<conv1_b<BR/><B>Parameter</B><BR/>[1, 16, 1, 1]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "40" [label=<conv1_K<BR/><B>Parameter</B><BR/>[16, 3, 3, 3]<BR/>(432 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "6" [label=<dropout_1<BR/><B>Dropout</B><BR/>[?, 128]<BR/>(p=0.3)> shape=diamond style=filled fillcolor="#E1BEE7" fontsize=10];
        "8" [label=<relu_1<BR/><B>ReLU</B><BR/>[?, 128]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "12" [label=<flatten_1<BR/><B>Flatten</B><BR/>[?, 1568]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "14" [label=<pool2_out_1<BR/><B>MaxPool2d</B><BR/>[?, 32, 7, 7]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "15" [label=<relu_2<BR/><B>ReLU</B><BR/>[?, 32, 14, 14]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "26" [label=<pool1_out_1<BR/><B>MaxPool2d</B><BR/>[?, 16, 14, 14]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "28" [label=<relu_3<BR/><B>ReLU</B><BR/>[?, 16, 28, 28]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "39" [label=<input_1<BR/><B>Input</B><BR/>[?, 3, 28, 28]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

