        subgraph cluster_ChessPieceCNN_group_batchnorm_1 {
            label=<<B>bn1</B><BR/><FONT POINT-SIZE="9">BatchNorm: C=16</FONT>>;
            style=filled;
            fillcolor="#F3E5F540";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "29" [label=<add_4<BR/><B>Add</B><BR/>[?, 16, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "30" [label=<multiply_2<BR/><B>Multiply</B><BR/>[?, 16, 28, 28]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
