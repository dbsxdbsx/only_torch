digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_ParityGRU {
        label=<<B>ParityGRU</B><BR/><FONT POINT-SIZE="9">(898 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_ParityGRU_fc {
            label=<<B>fc</B><BR/><FONT POINT-SIZE="9">Linear: [?, 16] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<fc_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "6" [label=<fc_W<BR/><B>Parameter</B><BR/>[16, 2]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ParityGRU_gru {
            label=<<B>gru</B><BR/><FONT POINT-SIZE="9">GRU: [?, 1] → [?, 16] (×4-12 steps)</FONT>>;
            style="filled,bold";
            peripheries=3;
            penwidth=2;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "7" [label=<gru_b_n<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "8" [label=<gru_b_z<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "9" [label=<gru_W_in<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "11" [label=<gru_W_hn<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "12" [label=<gru_W_iz<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "13" [label=<gru_W_hz<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "14" [label=<gru_b_r<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "15" [label=<gru_W_ir<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "16" [label=<gru_W_hr<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "17" [label=<add_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "18" [label=<tanh_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Tanh</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "19" [label=<multiply_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "20" [label=<add_3 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "21" [label=<sigmoid_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "22" [label=<subtract_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Subtract</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "23" [label=<add_4 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "24" [label=<add_5 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "25" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 16]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
                "26" [label=<matmul_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "27" [label=<multiply_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "28" [label=<add_6 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "29" [label=<select_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "30" [label=<sigmoid_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "31" [label=<matmul_3 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "32" [label=<matmul_4 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "33" [label=<matmul_5 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "34" [label=<add_7 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "35" [label=<add_8 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "36" [label=<matmul_6 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "37" [label=<matmul_7 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
        }

        "10" [label=<input_1<BR/><B>Input</B><BR/>[?, 4-12, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 2]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "17" -> "4" [ color="#E67E22" label=<t=3~11> fontcolor="#E67E22" fontsize=9];
    "6" -> "4";
    "18" -> "17";
    "19" -> "17";
    "20" -> "18";
    "21" -> "19";
    "22" -> "19";
    "23" -> "20";
    "7" -> "20";
    "24" -> "21";
    "25" -> "22";
    "18" -> "22";
    "26" -> "23";
    "27" -> "23";
    "28" -> "24";
    "8" -> "24";
    "10" -> "25" [ style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "29" -> "26";
    "9" -> "26";
    "30" -> "27";
    "31" -> "27";
    "32" -> "28";
    "33" -> "28";
    "10" -> "29";
    "34" -> "30";
    "25" -> "31";
    "11" -> "31";
    "29" -> "32";
    "12" -> "32";
    "25" -> "33";
    "13" -> "33";
    "35" -> "34";
    "14" -> "34";
    "36" -> "35";
    "37" -> "35";
    "29" -> "36";
    "15" -> "36";
    "25" -> "37";
    "16" -> "37";
    "17" -> "25" [style=dashed color="#E67E22" label=<t=0~(2~10)> fontcolor="#E67E22" fontsize=9 constraint=false];
}
