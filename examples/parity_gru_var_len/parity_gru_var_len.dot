digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_ParityGRU {
        label=<<B>ParityGRU</B><BR/><FONT POINT-SIZE="9">(898 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_ParityGRU_fc {
            label=<<B>fc</B><BR/><FONT POINT-SIZE="9">Linear: [?, 16] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<fc_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<fc_W<BR/><B>Parameter</B><BR/>[16, 2]<BR/>(32 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_ParityGRU_gru {
            label=<<B>gru</B><BR/><FONT POINT-SIZE="9">GRU: [?, 1] → [?, 16] (×4-12 steps)</FONT>>;
            style="filled,bold";
            peripheries=3;
            penwidth=2;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
            "14" [label=<gru_b_n<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "20" [label=<gru_b_z<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "24" [label=<gru_W_in<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "34" [label=<gru_W_hn<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "35" [label=<gru_W_iz<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "36" [label=<gru_W_hz<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "41" [label=<gru_b_r<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "57" [label=<gru_W_ir<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "58" [label=<gru_W_hr<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "222" [label=<add_75 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "227" [label=<tanh_12 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Tanh</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "228" [label=<multiply_23 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "236" [label=<add_78 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "237" [label=<sigmoid_23 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "238" [label=<subtract_12 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Subtract</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "240" [label=<add_80 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "241" [label=<add_81 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "242" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 16]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
            "244" [label=<matmul_66 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "245" [label=<multiply_24 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "246" [label=<add_83 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "249" [label=<select_12 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "250" [label=<sigmoid_24 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
            "251" [label=<matmul_69 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "252" [label=<matmul_70 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "253" [label=<matmul_71 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "254" [label=<add_84 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "255" [label=<add_85 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "256" [label=<matmul_72 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
            "257" [label=<matmul_73 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
        }

        "32" [label=<input_1<BR/><B>Input</B><BR/>[?, 4-12, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 2]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "222" -> "4" [color="#E67E22" label=<t=3~11> fontcolor="#E67E22" fontsize=9];
    "7" -> "4";
    "227" -> "222";
    "228" -> "222";
    "236" -> "227";
    "237" -> "228";
    "238" -> "228";
    "240" -> "236";
    "14" -> "236";
    "241" -> "237";
    "242" -> "238";
    "227" -> "238";
    "244" -> "240";
    "245" -> "240";
    "246" -> "241";
    "20" -> "241";
    "32" -> "242" [style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "249" -> "244";
    "24" -> "244";
    "250" -> "245";
    "251" -> "245";
    "252" -> "246";
    "253" -> "246";
    "32" -> "249";
    "254" -> "250";
    "242" -> "251";
    "34" -> "251";
    "249" -> "252";
    "35" -> "252";
    "242" -> "253";
    "36" -> "253";
    "255" -> "254";
    "41" -> "254";
    "256" -> "255";
    "257" -> "255";
    "249" -> "256";
    "57" -> "256";
    "242" -> "257";
    "58" -> "257";
    "222" -> "242" [style=dashed color="#E67E22" label=<t=0~(2~10)> fontcolor="#E67E22" fontsize=9 constraint=false];
}
