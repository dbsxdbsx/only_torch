                "8" [label=<lstm_W_io<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "9" [label=<lstm_W_ho<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "11" [label=<lstm_b_f<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "12" [label=<lstm_b_i<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "13" [label=<lstm_b_g<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "14" [label=<lstm_W_if<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "15" [label=<lstm_W_hf<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "16" [label=<lstm_W_ii<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "17" [label=<lstm_W_hi<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "18" [label=<lstm_W_ig<BR/><B>Parameter</B><BR/>[1, 16]<BR/>(16 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "19" [label=<lstm_W_hg<BR/><B>Parameter</B><BR/>[16, 16]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "20" [label=<add_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "21" [label=<multiply_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "22" [label=<multiply_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "23" [label=<sigmoid_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "24" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 16]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
                "25" [label=<sigmoid_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "26" [label=<tanh_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Tanh</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "27" [label=<add_3 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "28" [label=<add_4 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "29" [label=<add_5 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "30" [label=<multiply_3 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Multiply</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "31" [label=<add_6 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "32" [label=<add_7 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "33" [label=<add_8 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "34" [label=<sigmoid_3 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Sigmoid</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "35" [label=<tanh_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Tanh</B><BR/>[?, 16]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "36" [label=<matmul_2 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "37" [label=<matmul_3 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "38" [label=<matmul_4 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "39" [label=<matmul_5 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "40" [label=<matmul_6 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "41" [label=<matmul_7 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "42" [label=<add_9 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "43" [label=<select_1 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "44" [label=<add_10 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>Add</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "45" [label=<matmul_8 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "46" [label=<matmul_9 <FONT COLOR="#E67E22">×4-12</FONT><BR/><B>MatMul</B><BR/>[?, 16]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
        }

        "10" [label=<input_1<BR/><B>Input</B><BR/>[?, 4-12, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<softmax_ce_1<BR/><B>SoftmaxCrossEntropy</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
