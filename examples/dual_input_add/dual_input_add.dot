digraph Model {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_DualInputAdder {
        label=<<B>DualInputAdder</B><BR/><FONT POINT-SIZE="9">Model: 17 nodes</FONT>>;
        style=filled;
        fillcolor="#FFECB340";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=11;
        margin=12;
        subgraph cluster_DualInputAdder_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="8">Linear: [?, 1] → [?, 4]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=10;
            margin=8;
            "1" [label=<fc1_W<BR/><B>Parameter</B><BR/>[1, 4]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "2" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 4]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "9" [label=<mat_mul_1<BR/><B>MatMul</B><BR/>[?, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "10" [label=<add_1<BR/><B>Add</B><BR/>[?, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }
        subgraph cluster_DualInputAdder_fc2 {
            label=<<B>fc2</B><BR/><FONT POINT-SIZE="8">Linear: [?, 1] → [?, 4]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=10;
            margin=8;
            "3" [label=<fc2_W<BR/><B>Parameter</B><BR/>[1, 4]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "4" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 4]<BR/>(4 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "12" [label=<mat_mul_2<BR/><B>MatMul</B><BR/>[?, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "13" [label=<add_2<BR/><B>Add</B><BR/>[?, 4]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }
        subgraph cluster_DualInputAdder_fc_out {
            label=<<B>fc_out</B><BR/><FONT POINT-SIZE="8">Linear: [?, 8] → [?, 1]</FONT>>;
            style=filled;
            fillcolor="#FFF3E080";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=10;
            margin=8;
            "5" [label=<fc_out_W<BR/><B>Parameter</B><BR/>[8, 1]<BR/>(8 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "6" [label=<fc_out_b<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
            "16" [label=<mat_mul_3<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
            "17" [label=<add_3<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }
            "7" [label=<input_1<BR/><B>SmartInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E0E0E0" fontsize=10];
            "8" [label=<input_2<BR/><B>SmartInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E0E0E0" fontsize=10];
            "11" [label=<leaky_relu_1<BR/><B>LeakyReLU</B><BR/>[?, 4]<BR/>α=0> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
            "14" [label=<leaky_relu_2<BR/><B>LeakyReLU</B><BR/>[?, 4]<BR/>α=0> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
            "15" [label=<concat_1<BR/><B>Concat</B><BR/>[?, 8]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    }

    "18" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "19" [label=<mse_loss_1<BR/><B>MSELoss</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];

    "7" -> "9";
    "1" -> "9";
    "9" -> "10";
    "2" -> "10";
    "10" -> "11";
    "8" -> "12";
    "3" -> "12";
    "12" -> "13";
    "4" -> "13";
    "13" -> "14";
    "11" -> "15";
    "14" -> "15";
    "15" -> "16";
    "5" -> "16";
    "16" -> "17";
    "6" -> "17";
    "17" -> "19";
    "18" -> "19";
}
