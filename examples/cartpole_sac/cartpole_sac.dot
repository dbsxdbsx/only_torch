digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_Actor {
        label=<<B>Actor</B><BR/><FONT POINT-SIZE="9">(450 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_Actor_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 64]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "31" [label=<add_6<BR/><B>Add</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "37" [label=<matmul_6<BR/><B>MatMul</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "38" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 64]<BR/>(64 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "43" [label=<fc1_W<BR/><B>Parameter</B><BR/>[4, 64]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_Actor_fc2 {
            label=<<B>fc2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 64] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "13" [label=<add_2<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "18" [label=<matmul_2<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "19" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "26" [label=<fc2_W<BR/><B>Parameter</B><BR/>[64, 2]<BR/>(128 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "9" [label=<softmax_1<BR/><B>Softmax</B><BR/>[?, 2]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "20" [label=<log_softmax_1<BR/><B>LogSoftmax</B><BR/>[?, 2]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "25" [label=<leaky_relu_2<BR/><B>LeakyReLU</B><BR/>[?, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    }

    subgraph cluster_model_Critic1 {
        label=<<B>Critic1</B><BR/><FONT POINT-SIZE="9">(450 params)</FONT>>;
        style="filled,bold";
        fillcolor="#E8EAF640";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_Critic1_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 64]</FONT>>;
            style=filled;
            fillcolor="#FFF3E080";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "24" [label=<add_3<BR/><B>Add</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "29" [label=<matmul_3<BR/><B>MatMul</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "30" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 64]<BR/>(64 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "36" [label=<fc1_W<BR/><B>Parameter</B><BR/>[4, 64]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "44" [label=<add_7<BR/><B>Add</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "46" [label=<matmul_7<BR/><B>MatMul</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }

        subgraph cluster_Critic1_fc2 {
            label=<<B>fc2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 64] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#F3E5F580";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "7" [label=<add_1<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "11" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "12" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "17" [label=<fc2_W<BR/><B>Parameter</B><BR/>[64, 2]<BR/>(128 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "27" [label=<add_4<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "32" [label=<matmul_4<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        }

        "16" [label=<leaky_relu_1<BR/><B>LeakyReLU</B><BR/>[?, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "22" [label=<identity_1<BR/><B>Identity</B><BR/>[?, 2]> shape=ellipse style="filled,dashed" fillcolor="#E1BEE7" fontsize=10];
        "35" [label=<input_2<BR/><B>Input</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
        "39" [label=<leaky_relu_3<BR/><B>LeakyReLU</B><BR/>[?, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    }

    subgraph cluster_model_Critic2 {
        label=<<B>Critic2</B><BR/><FONT POINT-SIZE="9">(450 params)</FONT>>;
        style="filled,bold";
        fillcolor="#E0F2F140";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_Critic2_fc1 {
            label=<<B>fc1</B><BR/><FONT POINT-SIZE="9">Linear: [?, 4] → [?, 64]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "45" [label=<add_8<BR/><B>Add</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "47" [label=<matmul_8<BR/><B>MatMul</B><BR/>[?, 64]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "48" [label=<fc1_b<BR/><B>Parameter</B><BR/>[1, 64]<BR/>(64 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "49" [label=<fc1_W<BR/><B>Parameter</B><BR/>[4, 64]<BR/>(256 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_Critic2_fc2 {
            label=<<B>fc2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 64] → [?, 2]</FONT>>;
            style=filled;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "28" [label=<add_5<BR/><B>Add</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "33" [label=<matmul_5<BR/><B>MatMul</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "34" [label=<fc2_b<BR/><B>Parameter</B><BR/>[1, 2]<BR/>(2 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "41" [label=<fc2_W<BR/><B>Parameter</B><BR/>[64, 2]<BR/>(128 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        "23" [label=<identity_2<BR/><B>Identity</B><BR/>[?, 2]> shape=ellipse style="filled,dashed" fillcolor="#E1BEE7" fontsize=10];
        "40" [label=<leaky_relu_4<BR/><B>LeakyReLU</B><BR/>[?, 64]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
    }

    "1" [label=<mean_1<BR/><B>Mean</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "2" [label=<mse_1<BR/><B>MSE</B><BR/>[?, 1]> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10];
    "3" [label=<sum_1<BR/><B>Sum</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "4" [label=<gather_1<BR/><B>Gather</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "5" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];
    "6" [label=<multiply_1<BR/><B>Multiply</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "8" [label=<input_1<BR/><B>Input</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    "10" [label=<subtract_1<BR/><B>Subtract</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "14" [label=<multiply_2<BR/><B>Multiply</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "15" [label=<minimum_1<BR/><B>Minimum</B><BR/>[?, 2]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
    "21" [label=<α_1<BR/><B>Input</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    "42" [label=<obs_1<BR/><B>Input</B><BR/>[?, 4]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];

    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "3";
    "7" -> "4";
    "8" -> "4";
    "9" -> "6";
