digraph ComputeGraph {
    rankdir=TB;
    newrank=true;
    splines=polyline;
    node [fontname="Microsoft YaHei,SimHei,Arial"];
    edge [fontname="Microsoft YaHei,SimHei,Arial"];

    subgraph cluster_model_EvolutionNet {
        label=<<B>EvolutionNet</B><BR/><FONT POINT-SIZE="9">(151 params)</FONT>>;
        style="filled,bold";
        fillcolor="#FFEBEE40";
        fontname="Microsoft YaHei,SimHei,Arial";
        fontsize=13;
        margin=16;

        subgraph cluster_EvolutionNet_evo_L2 {
            label=<<B>evo_L2</B><BR/><FONT POINT-SIZE="9">Linear: [?, 6] → [?, 1]</FONT>>;
            style=filled;
            fillcolor="#E3F2FD80";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "2" [label=<add_1<BR/><B>Add</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "4" [label=<matmul_1<BR/><B>MatMul</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
                "5" [label=<evo_L2_b<BR/><B>Parameter</B><BR/>[1, 1]<BR/>(1 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "7" [label=<evo_L2_W<BR/><B>Parameter</B><BR/>[6, 1]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
        }

        subgraph cluster_EvolutionNet_evo_gru5 {
            label=<<B>evo_gru5</B><BR/><FONT POINT-SIZE="9">GRU: [?, 1] → [?, 6] (×8 steps)</FONT>>;
            style="filled,bold";
            peripheries=3;
            penwidth=2;
            fillcolor="#E8F5E980";
            fontname="Microsoft YaHei,SimHei,Arial";
            fontsize=11;
            margin=12;
                "11" [label=<evo_gru5_b_n<BR/><B>Parameter</B><BR/>[1, 6]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "12" [label=<evo_gru5_b_z<BR/><B>Parameter</B><BR/>[1, 6]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "13" [label=<evo_gru5_W_in<BR/><B>Parameter</B><BR/>[1, 6]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "15" [label=<evo_gru5_W_hn<BR/><B>Parameter</B><BR/>[6, 6]<BR/>(36 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "16" [label=<evo_gru5_W_iz<BR/><B>Parameter</B><BR/>[1, 6]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "17" [label=<evo_gru5_W_hz<BR/><B>Parameter</B><BR/>[6, 6]<BR/>(36 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "18" [label=<evo_gru5_b_r<BR/><B>Parameter</B><BR/>[1, 6]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "19" [label=<evo_gru5_W_ir<BR/><B>Parameter</B><BR/>[1, 6]<BR/>(6 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "20" [label=<evo_gru5_W_hr<BR/><B>Parameter</B><BR/>[6, 6]<BR/>(36 params)> shape=box style=filled fillcolor="#E8F5E9" fontsize=10];
                "21" [label=<add_3 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "22" [label=<tanh_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Tanh</B><BR/>[?, 6]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "23" [label=<multiply_2 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Multiply</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "24" [label=<add_4 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "25" [label=<sigmoid_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Sigmoid</B><BR/>[?, 6]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "26" [label=<subtract_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Subtract</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "27" [label=<add_5 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "28" [label=<add_6 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "29" [label=<zeros_like_1 <FONT COLOR="#E67E22">×1</FONT><BR/><B>ZerosLike</B><BR/>[?, 6]> shape=box style="filled,rounded,dashed" fillcolor="#FFFDE7" fontsize=10];
                "30" [label=<matmul_2 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "31" [label=<multiply_3 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Multiply</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "32" [label=<add_7 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "33" [label=<select_1 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Select</B><BR/>[?, 1]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "34" [label=<sigmoid_2 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Sigmoid</B><BR/>[?, 6]> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10 peripheries=2];
                "35" [label=<matmul_3 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "36" [label=<matmul_4 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "37" [label=<matmul_5 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "38" [label=<add_8 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "39" [label=<add_9 <FONT COLOR="#E67E22">×8</FONT><BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "40" [label=<matmul_6 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
                "41" [label=<matmul_7 <FONT COLOR="#E67E22">×8</FONT><BR/><B>MatMul</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10 peripheries=2];
        }

        "6" [label=<multiply_1<BR/><B>Multiply</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "8" [label=<add_2<BR/><B>Add</B><BR/>[?, 6]> shape=box style="filled,rounded" fillcolor="#FFFDE7" fontsize=10];
        "9" [label=<input_1<BR/><B>Input</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
        "10" [label=<leaky_relu_1<BR/><B>LeakyReLU</B><BR/>[?, 6]<BR/>(α=0.01)> shape=diamond style=filled fillcolor="#FFF3E0" fontsize=10];
        "14" [label=<evo_input_1<BR/><B>Input</B><BR/>[?, 8, 1]> shape=ellipse style=filled fillcolor="#E3F2FD" fontsize=10];
    }

    "1" [label=<mse_1<BR/><B>MSE</B><BR/>[?, 1]<BR/><FONT COLOR="#C62828" POINT-SIZE="9">▸ Output</FONT>> shape=octagon style=filled fillcolor="#FFEBEE" fontsize=10 penwidth=2.5 color="#C62828"];
    "3" [label=<target_1<BR/><B>TargetInput</B><BR/>[?, 1]> shape=ellipse style=filled fillcolor="#FFE0B2" fontsize=10];

    "2" -> "1";
    "3" -> "1";
    "4" -> "2";
    "5" -> "2";
    "6" -> "4";
    "7" -> "4";
    "8" -> "6";
    "9" -> "6";
    "10" -> "8";
    "21" -> "8" [ color="#E67E22" label=<t=7> fontcolor="#E67E22" fontsize=9];
    "21" -> "10" [ color="#E67E22" label=<t=7> fontcolor="#E67E22" fontsize=9];
    "22" -> "21";
    "23" -> "21";
    "24" -> "22";
    "25" -> "23";
    "26" -> "23";
    "27" -> "24";
    "11" -> "24";
    "28" -> "25";
    "29" -> "26";
    "22" -> "26";
    "30" -> "27";
    "31" -> "27";
    "32" -> "28";
    "12" -> "28";
    "14" -> "29" [ style=dashed color="#E67E22" label=<t=0> fontcolor="#E67E22" fontsize=9];
    "33" -> "30";
    "13" -> "30";
    "34" -> "31";
    "35" -> "31";
    "36" -> "32";
    "37" -> "32";
    "14" -> "33";
    "38" -> "34";
    "29" -> "35";
    "15" -> "35";
    "33" -> "36";
    "16" -> "36";
    "29" -> "37";
    "17" -> "37";
    "39" -> "38";
    "18" -> "38";
    "40" -> "39";
    "41" -> "39";
    "33" -> "40";
    "19" -> "40";
    "29" -> "41";
    "20" -> "41";
    "21" -> "29" [style=dashed color="#E67E22" label=<t=0~6> fontcolor="#E67E22" fontsize=9 constraint=false];
}
